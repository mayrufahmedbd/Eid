// ====== STUDY PLAN DATA ======
const studyPlan = {
  exam_date: "July 2",
  total_days: 60,

  phases: [
    { name: "Fast Coverage", days: "1-25" },
    { name: "Practice + Writing", days: "26-45" },
    { name: "Revision + Suggestion", days: "46-60" }
  ],

  priority: {
    high: ["English 2nd", "Bangla 2nd", "ICT"],
    medium: ["Economics", "Civics"],
    practice: ["Logic"],
    easy: ["Islam"]
  },

  daily_routine: [
    {
      session: "Morning",
      time: "6:00-9:00",
      tasks: ["English 2nd Grammar", "ICT"]
    },
    {
      session: "Midday",
      time: "11:00-1:30",
      tasks: ["Economics", "Civics"]
    },
    {
      session: "Evening",
      time: "4:00-6:30",
      tasks: ["Bangla", "Logic"]
    },
    {
      session: "Night",
      time: "8:00-10:00",
      tasks: ["Islam", "Revision"]
    }
  ],

  subjects: {
    "English 2nd": ["Tense", "Voice", "Narration", "Preposition", "Article"],
    "Bangla 2nd": ["Grammar", "Essay", "Paragraph", "Letter"],
    "ICT": ["Number System", "Database", "Networking", "HTML"],
    "Economics": ["Demand", "Inflation", "Graphs", "Definitions"],
    "Civics": ["Constitution", "Rights", "Governance"],
    "Logic": ["Syllogism", "Fallacies"],
    "Islam": ["Short Questions", "Structured Answers"],
    "English 1st": ["Seen Passage", "Summary"],
    "Bangla 1st": ["Important Questions", "Summary"]
  },

  daily_rules: [
    "Learn 2-3 topics",
    "Write 3-5 answers",
    "Revise 1 hour",
    "No mobile distraction"
  ]
};


// ====== RENDER FUNCTION ======
function renderPlan() {
  const app = document.getElementById("app");

  // Goal
  app.innerHTML += `
    <div class="card">
      <h2>🎯 Target</h2>
      <p>Exam: ${studyPlan.exam_date}</p>
      <p>Days Left: ${studyPlan.total_days}</p>
    </div>
  `;

  // Phases
  app.innerHTML += `<h2>📅 Phases</h2>`;
  studyPlan.phases.forEach(p => {
    app.innerHTML += `<div class="card">${p.name} (${p.days})</div>`;
  });

  // Routine
  app.innerHTML += `<h2>⏰ Daily Routine</h2>`;
  studyPlan.daily_routine.forEach(r => {
    app.innerHTML += `
      <div class="card">
        <strong>${r.session}</strong> (${r.time})
        <ul>
          ${r.tasks.map(t => `<li>${t}</li>`).join("")}
        </ul>
      </div>
    `;
  });

  // Subjects
  app.innerHTML += `<h2>📚 Subjects Focus</h2>`;
  for (let sub in studyPlan.subjects) {
    app.innerHTML += `
      <div class="card">
        <strong>${sub}</strong>
        <ul>
          ${studyPlan.subjects[sub].map(t => `<li>${t}</li>`).join("")}
        </ul>
      </div>
    `;
  }

  // Rules
  app.innerHTML += `<h2>⚡ Rules</h2><ul>`;
  studyPlan.daily_rules.forEach(r => {
    app.innerHTML += `<li>${r}</li>`;
  });
  app.innerHTML += `</ul>`;
}


// ====== SIMPLE PROGRESS TRACKER ======
function addProgressTracker() {
  const tracker = document.createElement("div");
  tracker.className = "card";

  tracker.innerHTML = `
    <h2>✅ Daily Progress</h2>
    <label><input type="checkbox"> Studied Today</label><br>
    <label><input type="checkbox"> Wrote Answers</label><br>
    <label><input type="checkbox"> Revision Done</label>
  `;

  document.getElementById("app").prepend(tracker);
}


// ====== INIT ======
window.onload = () => {
  renderPlan();
  addProgressTracker();
};